# Copy this file to .env.local and fill in the values.
# (Filename is "env.example" without the leading dot so this repo can
#  ship under environments that block .env-prefixed file edits.)

# === Supabase ===
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only (do NOT expose to the browser). Used for admin tasks if needed.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# === OpenRouter (AI features) ===
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# === App ===
# Used as the OAuth redirect base and OpenRouter HTTP-Referer.
NEXT_PUBLIC_APP_URL=http://localhost:3000
